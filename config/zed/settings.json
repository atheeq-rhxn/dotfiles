{
  "extend_comment_on_newline": false,
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "cursor_blink": false,
  "ui_font_family": "Roboto",
  "buffer_font_family": "JetBrains Mono",
  "scrollbar": {
    "show": "never",
  },
  "ui_font_size": 20.0,
  "buffer_font_size": 20.0,
  "project_panel": {
    "default_width": 400.0,
    "dock": "right",
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "theme": {
    "light": "Catppuccin Latte (Blur) [Light]",
    "dark": "Catppuccin Mocha (Blur) [Light]",
  },
  "helix_mode": true,
  "disable_ai": true,
  "icon_theme": {
    "light": "Catppuccin Mocha",
    "dark": "Catppuccin Mocha",
  },
}
